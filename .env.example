# Provider (default: anthropic)
ANTHROPIC_API_KEY=your-key-here
# PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Agent
AGENT_NAME=wally
AGENT_PORT=3456
# AGENT_MODEL=claude-sonnet-4-6   # OpenAI default: gpt-4o
# AGENT_TIMEOUT_MS=300000          # HTTP chat timeout in ms (default: 5 min)

# Telegram (optional — both required if enabling)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_ID=

# HTTP auth (optional) — if set, protected endpoints require X-Api-Key header
# API_KEY=change-me

# Skills — comma-separated to restrict; omit to auto-discover all
# ENABLED_SKILLS=wallet
